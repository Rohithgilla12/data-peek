{
  "name": "@data-peek/desktop",
  "version": "0.25.0",
  "description": "A minimal, fast database client",
  "main": "./out/main/index.js",
  "author": "Rohith Gilla",
  "homepage": "https://github.com/Rohithgilla12/data-peek",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "test": "vitest run",
    "test:electron": "ELECTRON_RUN_AS_NODE=1 electron ../../node_modules/vitest/vitest.mjs run src/main/__tests__/time-machine-storage.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm run build && playwright test",
    "test:e2e:ui": "pnpm run build && playwright test --ui",
    "test:e2e:debug": "pnpm run build && PWDEBUG=1 playwright test",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "pnpm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps || true",
    "build:unpack": "pnpm run build && electron-builder --dir",
    "build:win": "pnpm run build && electron-builder --win",
    "build:mac": "pnpm run build && electron-builder --mac",
    "build:linux": "pnpm run build && electron-builder --linux"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.85",
    "@ai-sdk/google": "^2.0.78",
    "@ai-sdk/groq": "^2.0.43",
